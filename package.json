{
  "name": "code-slicer",
  "version": "0.4.2",
  "description": "Extract minimal, dependency-aware code context from an entry file for use in AI prompts.",
  "keywords": [
    "ai",
    "cli",
    "code",
    "context",
    "dependencies",
    "esm",
    "imports",
    "prompt",
    "typescript"
  ],
  "homepage": "https://github.com/Deasilsoft/code-slicer",
  "bugs": {
    "url": "https://github.com/Deasilsoft/code-slicer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deasilsoft/code-slicer.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "code-slicer": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin.js",
    "clean": "npm run clean:install && npm run clean:package",
    "preclean:install": "rm -rf node_modules package-lock.json",
    "clean:install": "npm install",
    "clean:package": "rm -rf dist coverage",
    "dev": "tsx src/bin.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run clean:package && npm run build",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/compiler-sfc": "^3.5.33",
    "eslint": "^10.2.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "knip": "^6.9.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
